{
  "name": "bridge-plus",
  "version": "1.0.5",
  "description": "BRIDGE+ — independent interoperability tool for compatible DJ, visual, lighting, and timecode workflows",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "headless": "node bridge-core.js --demo",
    "test": "for f in tests/*.test.js; do node \"$f\" || exit 1; done; echo '✓ all tests passed'",
    "dist:mac": "electron-builder --mac --x64 --arm64",
    "dist:win": "electron-builder --win --x64",
    "dist:all": "electron-builder -mw",
    "pack": "electron-builder --dir"
  },
  "keywords": [
    "dj",
    "lighting",
    "timecode",
    "resolume",
    "tcnet",
    "artnet"
  ],
  "license": "Apache-2.0",
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.zesminseok.bridgeplus",
    "productName": "BRIDGE+",
    "copyright": "Copyright © 2026 Zesminseok",
    "icon": "build/icon.png",
    "afterSign": "scripts/after-sign-adhoc.js",
    "directories": {
      "output": "dist"
    },
    "npmRebuild": false,
    "asar": true,
    "asarUnpack": [
      "**/*.node",
      "vendor/abletonlink-mini/build/Release/**"
    ],
    "artifactName": "${productName}-1.0.5-${os}-${arch}.${ext}",
    "files": [
      "main.js",
      "main/**/*",
      "bridge-core.js",
      "bridge/**/*",
      "pdjl/**/*",
      "tcnet/**/*",
      "license-service.js",
      "preload.js",
      "renderer/**/*",
      "vendor/abletonlink-mini/index.js",
      "vendor/abletonlink-mini/index.d.ts",
      "vendor/abletonlink-mini/package.json",
      "vendor/abletonlink-mini/build/Release/abletonlink_mini.node",
      "default-album-artwork.png",
      "LICENSE",
      "NOTICE.md",
      "!**/*.map",
      "!**/*.pcap",
      "!**/*.pcapng",
      "!**/*.cap",
      "!**/*.har",
      "!**/*.log",
      "!**/*.tgz",
      "!**/*.pdf",
      "!captures/**",
      "!research/**",
      "!analysis/**",
      "!graphify-out/**",
      "!.codex-artifacts/**",
      "!tools/**",
      "!tests/**",
      "!package/**",
      "!juce-app/**",
      "!docs/**",
      "!.serena/**",
      "!.claude/**"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.music",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null
    },
    "dmg": {
      "writeUpdateInfo": false,
      "sign": false
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "portable": {
      "artifactName": "${productName}-1.0.5-${os}-${arch}-portable.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    }
  },
  "dependencies": {
    "bindings": "^1.5.0",
    "node-addon-api": "^7.0.0"
  }
}
